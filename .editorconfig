# EditorConfig — consistent formatting across the mixed Windows/WSL workflow.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 88

[*.{js,json,yml,yaml}]
indent_size = 2

[*.md]
# Trailing whitespace can be meaningful (hard line breaks) in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
